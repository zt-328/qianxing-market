"{\"status\":200,\"headers\":\"accept-ranges: bytes\\r\\naccess-control-allow-origin: *\\r\\ncache-control: public, max-age=0\\r\\ncontent-length: 158026\\r\\ncontent-type: application/javascript; charset=UTF-8\\r\\ndate: Fri, 17 Jul 2026 06:22:42 GMT\\r\\netag: W/\\\"2694a-19f63d0df2f\\\"\\r\\nlast-modified: Wed, 15 Jul 2026 03:27:40 GMT\\r\\nx-powered-by: Express\\r\\n\",\"bodyLen\":150957,\"bodyPreview\":\"// ==================== App Core ====================\\nconst App = {\\n  state: {\\n    user: null,\\n    currentView: 'overview',\\n    employees: [],\\n    tasks: [],\\n    materials: { categories: [], materials: [] },\\n    stats: {},\\n    config: {},\\n    previewMode: false\\n  },\\n\\n  api(url, options = {}) {\\n    return fetch(url, { headers: { 'Content-Type': 'application/json' }, ...options })\\n      .then(r => r.json())\\n      .catch(err => ({ ok: false, message: '网络错误，请确认服务已启动 (http://localhost:3456)', _error: err.message }));\\n  },\\n\\n  // ---- Toast ----\\n  toast(msg, type = 'info') {\\n    const c = document.getElementById('toastContainer');\\n    const el = document.createElement('div');\\n    el.className = 'toast ' + type;\\n    el.textContent = msg;\\n    c.appendChild(el);\\n    setTimeout(() => { el.style.opacity = '0'; setTimeout(() => el.remove(), 300); }, 3000);\\n  },\\n\\n  // ---- Modal ----\\n  showModal(title, bodyHTML, footerHTML) {\\n    const c = document.getElementById('modalContainer');\\n    const h = `\\n      <div class=\\\"modal-overlay\\\" onclick=\\\"if(event.target===this)App.closeModal()\\\">\\n        <div class=\\\"modal\\\">\\n          <div class=\\\"modal-header\\\"><h4>${title}</h4><button class=\\\"modal-close\\\" onclick=\\\"App.closeModal()\\\">&times;</button></div>\\n          <div class=\\\"modal-body\\\">${bodyHTML}</div>\\n          ${footerHTML ? `<div class=\\\"modal-footer\\\">${footerHTML}</div>` : ''}\\n        </div>\\n      </div>`;\\n    c.innerHTML = h;\\n  },\\n\\n  closeModal() { document.getElementById('modalContainer').innerHTML = ''; },\\n\\n  // ---- Login ----\\n  async login() {\\n    const name = document.getElementById('loginName').value.trim();\\n    const pass = document.getElementById('loginPass').value.trim();\\n    if (!name || !pass) { this.showLoginError('请输入姓名和密码'); return; }\\n    const res = await this.api('/api/auth/login', { method: 'POST', body: JSON.stringify({ name, password: pass }) });\\n    if (!res.ok) { this.showLoginError(res.message || '登录失败'); return; }\\n    this.state.user = res.employee;\\n    this.state.comp\"}"